{
  "name": "adviz",
  "version": "0.1.0",
  "description": "LLM-led WebGPU creative graphics framework",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "VITE_MODE=demo vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:single": "vitest run --reporter=verbose",
    "lint": "eslint src examples",
    "lint:fix": "eslint src examples --fix",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\"",
    "typecheck": "tsc --project tsconfig.app.json --noEmit",
    "docs": "typedoc",
    "publish:jsr": "npx jsr publish",
    "preview": "VITE_MODE=demo vite preview",
    "build:demo": "VITE_MODE=demo vite build"
  },
  "keywords": [
    "webgpu",
    "graphics",
    "creative-coding",
    "visualization",
    "llm"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.10",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "jsdom": "^29.0.1",
    "prettier": "^3.5.3",
    "typedoc": "^0.28.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
